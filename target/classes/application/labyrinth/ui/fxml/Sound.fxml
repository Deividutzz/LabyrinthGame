<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>

<?import javafx.scene.control.Slider?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Label?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="application.labyrinth.app.ui.controller.Sound"
           stylesheets="@/application/labyrinth/ui/css/AudioStyling.css"
           fx:id="root">

    <children>

        <ImageView fx:id="backgroundImg"/>

        <VBox spacing="20" alignment="CENTER">
            <Label text="Adjust the music volume:" />
            <Slider fx:id="volumeSlider" min="0" max="10" maxWidth="540"/>
            <Button fx:id="fullscreenButton" text="Set fullscreen"/>
            <Button fx:id="resetButton" text="Reset to default"/>
            <Button fx:id="backButton" text="Back"/>
        </VBox>

    </children>

</StackPane>