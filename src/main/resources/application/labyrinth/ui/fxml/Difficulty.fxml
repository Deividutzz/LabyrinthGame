<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>

<?import javafx.scene.control.Slider?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Label?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="application.labyrinth.app.ui.controller.Difficulty">

    <children>

        <ImageView fx:id="backgroundImg"/>

        <VBox spacing="20" alignment="CENTER" maxWidth="540">

            <Label fx:id="enemiesLabel" text="Set the number of enemies:" />
            <Slider fx:id="enemiesSlider" min="1" max="6"/>

            <Label fx:id="obstaclesLabel" text="Set the number of obstacles:" />
            <Slider fx:id="obstaclesSlider" min="30" max="100"/>

            <Label fx:id="speedLabel" text="Set the enemies speed:" />
            <Slider fx:id="speedSlider" min="1" max="10"/>

            <Button fx:id="backButton" text="Back"/>
        </VBox>

    </children>

</StackPane>