<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>

<?import javafx.scene.layout.Pane?>
<?import javafx.scene.image.ImageView?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="application.labyrinth.app.ui.controller.Game"
           stylesheets="@/application/labyrinth/ui/css/GameStyling.css"
           styleClass="game-root">

    <children>

        <!-- Static Layer (maze, walls, obstacles) -->
        <Pane fx:id="staticLayer"/>

        <!-- Entity Layer (player + enemies) -->
        <Pane fx:id="entityLayer"/>

    </children>

</StackPane>