<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>

<?import javafx.scene.media.MediaView?>
<?import javafx.scene.image.ImageView?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="application.labyrinth.app.ui.controller.Menu"
           stylesheets="@/application/labyrinth/ui/css/MenuStyling.css"
           fx:id="root">
    <children>

        <MediaView fx:id="backgroundVideo"/>
        <ImageView fx:id="backgroundGif"/>

        <VBox spacing="20" alignment="CENTER">
            <Button fx:id="startGameButton" text="Play Game"/>
            <Button fx:id="optionsButton" text="Options"/>
            <Button fx:id="exitButton" text="Exit Game"/>
        </VBox>

    </children>

</StackPane>
